{
  "name": "@raccoon/connector-openclaw",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@raccoon/bridge": "0.1.0",
    "@raccoon/pairing": "0.1.0",
    "@raccoon/push": "0.1.0",
    "@raccoon/transport-ws": "0.1.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.11"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": "^2026.6.11"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "channel": {
      "id": "raccoon",
      "label": "Raccoon",
      "blurb": "Self-hosted Raccoon messenger channel (installable PWA + push)."
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  }
}
