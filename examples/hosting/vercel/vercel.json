{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm ci && BUILD_ID=$VERCEL_GIT_COMMIT_SHA npm run build:app",
  "outputDirectory": "packages/app/dist-standalone",
  "framework": null,
  "headers": [
    {
      "source": "/(index.html|service-worker.js|version.json|manifest.webmanifest)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
