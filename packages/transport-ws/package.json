{
  "name": "@raccoon/transport-ws",
  "version": "0.1.0",
  "description": "Raccoon's built-in broker-free WebSocket transport: WsHub (server, static PWA serving, pairing) + WsClientTransport, with pluggable credential stores.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloudsignal/raccoon.git",
    "directory": "packages/transport-ws"
  },
  "homepage": "https://github.com/cloudsignal/raccoon#readme",
  "bugs": "https://github.com/cloudsignal/raccoon/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@raccoon/protocol": "0.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/client.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  }
}
