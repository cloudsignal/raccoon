{
  "extends": "../../tsconfig.build.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["src/lib.ts"],
  "exclude": [
    "src/main.tsx",
    "src/sw/**",
    "src/build/**",
    "src/vite-env.d.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
