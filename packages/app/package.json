{
  "name": "@raccoon/app",
  "version": "0.1.0",
  "description": "The Raccoon chat PWA: installable, push-capable React app plus the prebuilt static bundle (dist-standalone) any Raccoon hub can serve.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloudsignal/raccoon.git",
    "directory": "packages/app"
  },
  "homepage": "https://github.com/cloudsignal/raccoon#readme",
  "bugs": "https://github.com/cloudsignal/raccoon/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "files": [
    "dist",
    "dist-standalone",
    "raccoon.config.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "default": "./dist/lib.js"
    },
    "./styles.css": "./dist/styles.css",
    "./dist-standalone/*": "./dist-standalone/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && tailwindcss -i ./src/styles.css -o ./dist/styles.css --minify",
    "build:standalone": "vite build",
    "preview": "vite preview",
    "prepack": "npm run build && BUILD_ID=$npm_package_version npm run build:standalone"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@raccoon/protocol": "0.1.0",
    "@raccoon/transport-ws": "0.1.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.470.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0"
  }
}
